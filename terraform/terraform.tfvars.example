# terraform.tfvars.example
# Copie este arquivo para terraform.tfvars e customize com seus valores

# ============================================
# AWS Configuration
# ============================================
aws_region = "us-east-1"  # Mude para sua região preferida
                          # Opções: us-west-1, eu-west-1, ap-southeast-1, etc

# ============================================
# Project Configuration
# ============================================
project_name = "linux-lab"
environment  = "dev"

# ============================================
# Network Configuration
# ============================================
vpc_cidr    = "10.0.0.0/16"      # Private CIDR block for VPC
subnet_cidr = "10.0.1.0/24"      # Subnet dentro da VPC

# ============================================
# EC2 Configuration
# ============================================
instance_type      = "t2.micro"   # Free tier eligible
root_volume_size   = 8            # GB - root volume size

# IMPORTANTE: Você DEVE criar uma EC2 Key Pair antes ou deixar vazio
# Se deixar vazio (""), uma nova será criada automaticamente
key_pair_name      = ""           # Ex: "my-ec2-keypair"

# ============================================
# EBS Configuration
# ============================================
ebs_volume_size  = 5              # GB - Volume secundário para os exercícios
ebs_volume_type  = "gp3"          # General Purpose SSD
ebs_device_name  = "/dev/sdf"     # Device mapping

# ============================================
# Security - CUSTOMIZE ISSO!
# ============================================
# ⚠️ IMPORTANTE: "0.0.0.0/0" permite SSH de qualquer lugar
# Para melhor segurança, coloque seu IP único
# Exemplo: allowed_ssh_cidr = ["203.0.113.100/32"]

allowed_ssh_cidr = ["0.0.0.0/0"]  # MUDE ISSO PARA SEU IP!
                                   # Use: "YOUR_IP/32" para restringir
